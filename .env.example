# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# WhatsApp (whatsapp-web.js - solo en servidor local, no en Vercel)
# Código de país por defecto para formatear teléfonos (México = 52)
WHATSAPP_COUNTRY_CODE=52
# URL del frontend para generar links de pago en el bot
FRONTEND_URL=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=condominio_management
DB_SYNCHRONIZE=true
DB_LOGGING=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/condominio_management

# Supabase
SUPABASE_URL=https://iqezlunstkdppuwahbmm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@condominio.com

# Facturapi (CFDI 4.0)
# Obtén tu key en https://www.facturapi.io → Dashboard → API Keys
FACTURAPI_KEY=sk_test_SJDMTURvBB1rUYoQaXSDZKEiWLZjmLjWJ66zPcYBHk
FACTURAPI_MODE=test
# Para producción: usa sk_live_... y FACTURAPI_MODE=live

# CORS
CORS_ORIGIN=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
